# Social Data Ingestion RAG System Config

# LLM Engine: 'local' (uses Gemini via API Key) or 'openai' (uses GPT-4o-mini)
LLM_PROVIDER=local

# Embedding Engine: 'local' (uses SentenceTransformers locally, free) or 'openai' (uses text-embedding-3-small)
EMBEDDING_PROVIDER=local

# API Keys (Provide at least one if you want RAG chat capabilities)
# You can also set these dynamically in the Web UI Settings panel!
OPENAI_API_KEY=
GEMINI_API_KEY=
